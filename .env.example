# LLM Provider Configuration (choose at least one)
# OpenAI
OPENAI_API_KEY=your-openai-api-key
# OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key

# Google Gemini
GEMINI_API_KEY=your-gemini-api-key

# Azure DevOps Configuration
AZURE_DEVOPS_ORG_URL=your-org-url
AZURE_DEVOPS_PAT=your-personal-access-token

# Default LLM model to use
# Options: openai/gpt-4o, openai/gpt-4o-mini, anthropic/claude-3-opus, anthropic/claude-3-sonnet, gemini/gemini-1.5-pro, gemini/gemini-1.5-flash
DEFAULT_LLM_MODEL=openai/gpt-4o

# Team standards configuration path
TEAM_STANDARDS_PATH=./config/team-standards.json
